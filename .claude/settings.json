{
  "enabledPlugins": {
    "stripe@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm test*)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma db push)",
      "Bash(npx prisma studio)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "npx eslint --fix \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -qE '\\.env'; then echo 'BLOCK: Do not edit .env files directly — use environment variables documentation instead' && exit 1; fi"
      }
    ]
  }
}
