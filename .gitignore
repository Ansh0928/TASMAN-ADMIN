# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.eml

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Raw source images (converted to WebP in public/assets/products/)
public/assets/*.HEIC
public/assets/*.heic
public/assets/*.JPEG
public/assets/*.JPG
!public/assets/storefront.jpg
public/assets/*.MOV
public/assets/*.mov
public/assets/*.PNG
public/assets/*.doc
public/assets/*.pages
public/assets/*.dmg

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
