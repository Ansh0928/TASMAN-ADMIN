generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──

enum Role {
  CUSTOMER
  WHOLESALE
  ADMIN
}

enum WholesaleStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum Fulfillment {
  DELIVERY
  PICKUP
}

enum Unit {
  KG
  PIECE
  DOZEN
  BOX
  PACK
}

enum WholesaleOrderStatus {
  PENDING
  CONFIRMED
  REJECTED
  COMPLETED
}

// ── Users & Auth ──

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String?          @map("password_hash")
  name            String
  phone           String?
  image           String?          // Profile picture from Google OAuth
  authProvider    String?          @map("auth_provider") // "credentials" | "google"
  role            Role             @default(CUSTOMER)
  wholesaleStatus WholesaleStatus? @map("wholesale_status")
  companyName     String?          @map("company_name")
  abn             String?
  addresses         Address[]
  orders            Order[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  wholesaleOrders   WholesaleOrder[]
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("users")
}

model Address {
  id        String  @id @default(cuid())
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  street    String
  city      String
  state     String
  postcode  String
  isDefault Boolean @default(false) @map("is_default")

  @@map("addresses")
}

// ── Products ──

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?   @map("image_url")
  sortOrder   Int       @default(0) @map("sort_order")
  products    Product[]

  @@map("categories")
}

model Product {
  id                String      @id @default(cuid())
  name              String
  slug              String      @unique
  description       String?
  imageUrls         String[]    @map("image_urls")
  categoryId        String      @map("category_id")
  category          Category    @relation(fields: [categoryId], references: [id])
  price             Decimal     @db.Decimal(10, 2)
  stockQuantity     Int         @default(0) @map("stock_quantity")
  unit              Unit        @default(PIECE)
  isAvailable       Boolean     @default(true) @map("is_available")
  isFeatured        Boolean     @default(false) @map("is_featured")
  isTodaysSpecial   Boolean     @default(false) @map("is_todays_special")
  tags              String[]
  relatedProductIds String[]    @map("related_product_ids")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  orderItems        OrderItem[]

  @@map("products")
}

// ── Orders ──

model Order {
  id                  String        @id @default(cuid())
  userId              String?       @map("user_id")
  user                User?         @relation(fields: [userId], references: [id])
  guestEmail          String?       @map("guest_email")
  guestPhone          String?       @map("guest_phone")
  guestName           String?       @map("guest_name")
  status              OrderStatus   @default(PENDING)
  fulfillment         Fulfillment
  deliveryStreet      String?       @map("delivery_street")
  deliveryCity        String?       @map("delivery_city")
  deliveryState       String?       @map("delivery_state")
  deliveryPostcode    String?       @map("delivery_postcode")
  pickupTime          DateTime?     @map("pickup_time")
  subtotal            Decimal       @db.Decimal(10, 2)
  deliveryFee         Decimal       @default(0) @db.Decimal(10, 2) @map("delivery_fee")
  tax                 Decimal       @default(0) @db.Decimal(10, 2)
  total               Decimal       @db.Decimal(10, 2)
  stripePaymentIntent String?       @map("stripe_payment_intent")
  stripeSessionId     String?       @map("stripe_session_id")
  stripeInvoiceId     String?       @map("stripe_invoice_id")
  stripeInvoiceUrl    String?       @map("stripe_invoice_url")
  items               OrderItem[]
  notifications       Notification[]
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2) @map("unit_price")
  total     Decimal @db.Decimal(10, 2)

  @@map("order_items")
}

// ── Notifications ──

model Notification {
  id        String   @id @default(cuid())
  orderId   String?  @map("order_id")
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "EMAIL" or "SMS" or "PUSH"
  recipient String
  category  String?  // e.g. "wholesale_update", "order_status", "broadcast"
  status    String   // "SENT" or "FAILED"
  sentAt    DateTime @default(now()) @map("sent_at")

  @@map("notifications")
}

// ── Wholesale Price List (separate from retail products) ──

model WholesaleCategory {
  id        String               @id @default(cuid())
  name      String
  sortOrder Int                  @default(0) @map("sort_order")
  items     WholesalePriceItem[]

  @@map("wholesale_categories")
}

model WholesalePriceItem {
  id              String               @id @default(cuid())
  categoryId      String               @map("category_id")
  category        WholesaleCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  unit            String               // e.g. "per kg", "per box (10kg)", "each"
  price           Decimal              @db.Decimal(10, 2)
  isAvailable     Boolean              @default(true) @map("is_available")
  isTodaysSpecial Boolean              @default(false) @map("is_todays_special")
  isFeatured      Boolean              @default(false) @map("is_featured")
  sortOrder       Int                  @default(0) @map("sort_order")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  orderItems      WholesaleOrderItem[]

  @@map("wholesale_price_items")
}

// ── Push Subscriptions ──

model PushSubscription {
  id       String  @id @default(cuid())
  endpoint String  @unique
  p256dh   String
  auth     String
  userId   String? @map("user_id")
  user     User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("push_subscriptions")
}

// ── Wholesale Orders ──

model WholesaleOrder {
  id         String               @id @default(cuid())
  userId     String               @map("user_id")
  user       User                 @relation(fields: [userId], references: [id])
  status     WholesaleOrderStatus @default(PENDING)
  notes      String?
  adminNotes String?              @map("admin_notes")
  items      WholesaleOrderItem[]
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  @@map("wholesale_orders")
}

model WholesaleOrderItem {
  id                   String             @id @default(cuid())
  wholesaleOrderId     String             @map("wholesale_order_id")
  wholesaleOrder       WholesaleOrder     @relation(fields: [wholesaleOrderId], references: [id], onDelete: Cascade)
  wholesalePriceItemId String             @map("wholesale_price_item_id")
  wholesalePriceItem   WholesalePriceItem @relation(fields: [wholesalePriceItemId], references: [id])
  quantity             Int
  unitPrice            Decimal            @db.Decimal(10, 2) @map("unit_price")
  total                Decimal            @db.Decimal(10, 2)

  @@map("wholesale_order_items")
}
